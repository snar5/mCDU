{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src"
  },
  "package": {
    "productName": "mCDU Display",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.mcdu.display",
      "icon": ["icons/icon.png"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "mCDU Display",
        "width": 480,
        "height": 280,
        "minWidth": 240,
        "minHeight": 140,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  }
}
